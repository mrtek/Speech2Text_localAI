# --- Основное (Python) ---
venv/
.env
__pycache__/
*.py[cod]
*$py.class
*.log

# --- Модели ИИ (Тяжелые бинарные файлы) ---
# Игнорируем всю папку, где хранятся веса Whisper
models/

# --- Медиа и данные ---
# Папки для входящих и исходящих файлов
input/
output/

# Игнорируем любые аудио и видео файлы в корне и подпапках
*.mp3
*.wav
*.ogg
*.m4a
*.flac
*.mp4
*.mkv
*.avi

# Игнорируем результаты транскрибации (текстовые файлы)
# Чтобы случайно не залить личные переписки/интервью в открытый доступ
*_text.txt

# --- Бинарные утилиты ---
# FFmpeg и другие исполняемые файлы не должны быть в Git
*.exe
*.dll
ffmpeg.exe
ffprobe.exe
ffplay.exe

# --- Настройки редакторов и системы ---
.vscode/
.idea/
*.swp
*.bak
Thumbs.db
.DS_Store

# --- Сборка (если будешь делать .exe) ---
build/
dist/
*.spec